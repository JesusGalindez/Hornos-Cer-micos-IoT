# ============================================================================
# CONFIGURACIÓN DEL ENTORNO - BACKEND HORNOS IOT
# ============================================================================

PORT=3000
NODE_ENV=development

# ----------------------------------------------------------------------------
# CONEXIÓN A LA BASE DE DATOS (POSTGRES / TIMESCALEDB)
# ----------------------------------------------------------------------------
# Opción A: Cadena de conexión única (Recomendado para Neon.com)
DATABASE_URL=postgresql://neondb_owner:npg_Dsc2ud6JlkgX@ep-royal-haze-apeo80ad-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Opción B: Variables individuales (Usadas por defecto en el docker-compose local)
